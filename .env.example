# ─────────────────────────────────────────────────────────────────────────────
# PraOjas AI Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Gemini API Key — required for all AI agent features (Prediction, Explainability, Smart Vitals)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# ── OPTIONAL: Fine-Tuned Model ────────────────────────────────────────────────

# If you have a fine-tuned Gemini model, set its name here (e.g., tunedModels/my-model-123)
# If left blank, the system uses gemini-1.5-pro by default
GEMINI_TUNED_MODEL_NAME=""

# External PyTorch model endpoint (for the full PraOjas Multimodal Transformer)
# Leave blank to use the Gemini-based predictive agent fallback
PRAOJAS_MODEL_API_URL=""

# ── APP URL ──────────────────────────────────────────────────────────────────

# The URL where this app is hosted. For local dev, use:
APP_URL="http://localhost:3000"

# ── DATABASE (Optional for local dev) ────────────────────────────────────────
# If these vars are not set, the app will run without DB persistence.
# Patient data will be held in-memory only (resets on server restart).
# To enable persistence, install PostgreSQL locally and set these values.

# For local PostgreSQL (docker-compose sets these automatically):
#   SQL_HOST=localhost
#   SQL_USER=postgres
#   SQL_PASSWORD=postgres
#   SQL_DB_NAME=praojas
#   SQL_ADMIN_USER=postgres
#   SQL_ADMIN_PASSWORD=postgres

SQL_HOST=""
SQL_USER=""
SQL_PASSWORD=""
SQL_DB_NAME=""
SQL_ADMIN_USER=""
SQL_ADMIN_PASSWORD=""

# ── NODE ENVIRONMENT ─────────────────────────────────────────────────────────
# Set to "production" when running the compiled build (npm run start)
# For local dev with `npm run dev`, this is not needed (defaults to development)
# NODE_ENV=development
